# Copy to .env and fill in. Never commit .env.

# --- Supabase project ---
# Project URL (Settings -> API -> Project URL)
SUPABASE_URL=https://qnsbwdmjrjtbdwkqdtzj.supabase.co

# Publishable / anon key. Safe to ship to the frontend; backend uses it for
# user-scoped requests when forwarding a JWT.
SUPABASE_ANON_KEY=sb_publishable_qjsMRk3GANF0KAoL4b4D9w_qsy8w9gW

# Service role key. NEVER ship to the frontend. Used only for service-role
# operations (Relay webhook, admin scripts, bootstrap). Pull from Settings -> API.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret for verifying user tokens locally without round-tripping to
# Supabase auth. Settings -> API -> JWT Settings -> JWT Secret.
SUPABASE_JWT_SECRET=

# --- App ---
# Comma-separated list of allowed CORS origins for the React PWA.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Bootstrap (used by scripts/bootstrap_janelle.py only) ---
JANELLE_EMAIL=
JANELLE_PASSWORD=
